# === Base de données ===
DB_DATABASE=phabot
DB_USERNAME=phabot
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# === Microservice IA ===
# Modèle d'embeddings (HuggingFace) pour la base vectorielle
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Backend LLM : "ollama" (local, recommandé pour le dev) ou "openai"
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# Si LLM_BACKEND=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# === Notifications / file d'attente (côté Laravel, backend/.env) ===
# QUEUE_CONNECTION=database   # active le worker (service "queue")
# MAIL_MAILER=log             # en dev : les emails sont écrits dans storage/logs
